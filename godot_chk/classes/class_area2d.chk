*   gravity_point_center (Vector2). Default: Vector2(0, 1)
*   gravity_point_unit_distance (float). Default: 0.0
*   gravity_space_override (SpaceOverride). Default: 0
*   linear_damp (float). Default: 0.1
*   linear_damp_space_override (SpaceOverride). Default: 0
*   monitorable (bool). Default: true
*   monitoring (bool). Default: true
*   priority (int). Default: 0
