*   draw_skin (Skin):
*   emitting (bool): Default: true
*   explosiveness (float): Default: 0.0
*   fixed_fps (int): Default: 30
*   fract_delta (bool): Default: true
*   interp_to_end (float): Default: 0.0
*   interpolate (bool): Default: true
*   lifetime (float): Default: 1.0
*   local_coords (bool): Default: false
*   one_shot (bool): Default: false
*   preprocess (float): Default: 0.0
*   process_material (Material):
*   randomness (float): Default: 0.0
*   seed (int): Default: 0
*   speed_scale (float): Default: 1.0
*   sub_emitter (NodePath): Default: NodePath("")
*   trail_enabled (bool): Default: false
*   trail_lifetime (float): Default: 0.3
*   transform_align (TransformAlign): Default: 0
*   transform_align_axis (ParticlesTransformAlignAxis):
*   transform_align_channel_filter (ParticlesTransformAlignCustomSrc):
*   use_fixed_seed (bool): Default: false
*   visibility_aabb (AABB): Default: AABB(-4, -4, -4, 8, 8, 8)
