Document: VideoStreamPlayer
Path: godot/classes/class_videostreamplayer.rst
Summary: Describes the properties of the VideoStreamPlayer node for controlling video playback.

Property: audio_track
Type: int
Default: 0
Description: The embedded audio track to play.
Setter: set_audio_track(value: int)
Getter: get_audio_track() -> int

Property: autoplay
Type: bool
Default: false
Description: If true, playback starts when the scene loads.
Setter: set_autoplay(value: bool)
Getter: has_autoplay() -> bool

Property: buffering_msec
Type: int
Default: 500
Description: Amount of time in milliseconds to store in buffer while playing.
Setter: set_buffering_msec(value: int)
Getter: get_buffering_msec() -> int

Property: bus
Type: StringName
Default: "Master"
Description: Audio bus to use for sound playback.
Setter: set_bus(value: StringName)
Getter: get_bus() -> StringName

Property: expand
Type: bool
Default: false
Description: If true, the video scales to the control size. Otherwise, the control minimum size will be automatically adjusted to match the video stream's dimensions.
Setter: set_expand(value: bool)
Getter: has_expand() -> bool

Property: loop
Type: bool
Default: false
Description: If true, the video restarts when it reaches its end.
Setter: set_loop(value: bool)
Getter: has_loop() -> bool

Property: paused
Type: bool
Default: false
Description: If true, the video is paused.
Setter: set_paused(value: bool)
Getter: is_paused() -> bool

Property: speed_scale
Type: float
Default: 1.0
Description: The stream's current speed scale. 1.0 is the normal speed, while 2.0 is double speed and 0.5 is half speed. A speed scale of 0.0 pauses the video, similar to setting paused to true.
Setter: set_speed_scale(value: float)
Getter: get_speed_scale() -> float

Property: stream
Type: VideoStream
Description: The assigned video stream. See description for supported formats.
Setter: set_stream(value: VideoStream)
Getter: get_stream() -> VideoStream

Property: stream_position
Type: float
Description: The current position of the stream, in seconds.
Setter: set_stream_position(value: float)
Getter: get_stream_position() -> float

Property: volume
Type: float
Description: Audio volume as a linear value.
Setter: set_volume(value: float)
Getter: get_volume() -> float

Property: volume_db
Type: float
Default: 0.0
Description: Audio volume in dB.
Setter: set_volume_db(value: float)
Getter: get_volume_db() -> float
